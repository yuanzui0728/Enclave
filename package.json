{
  "name": "yinjie-workspace",
  "description": "隐界 — AI 数字人社交模拟应用",
  "author": "yuanzui0728",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuanzui0728/yinjie-app.git"
  },
  "private": true,
  "packageManager": "pnpm@8.15.4",
  "scripts": {
    "dev": "node ./scripts/dev-services.mjs start workspace",
    "dev:raw": "turbo run dev --parallel --filter=@yinjie/app --filter=@yinjie/admin --filter=@yinjie/cloud-console --filter=@yinjie/cloud-api",
    "dev:stop": "node ./scripts/dev-services.mjs stop workspace",
    "dev:restart": "node ./scripts/dev-services.mjs restart workspace",
    "dev:status": "node ./scripts/dev-services.mjs status workspace",
    "dev:all": "node ./scripts/dev-services.mjs start all",
    "dev:all:stop": "node ./scripts/dev-services.mjs stop all",
    "dev:all:restart": "node ./scripts/dev-services.mjs restart all",
    "dev:all:status": "node ./scripts/dev-services.mjs status all",
    "dev:app": "node ./scripts/dev-services.mjs start app",
    "dev:app:stop": "node ./scripts/dev-services.mjs stop app",
    "dev:app:restart": "node ./scripts/dev-services.mjs restart app",
    "dev:app:status": "node ./scripts/dev-services.mjs status app",
    "dev:admin": "node ./scripts/dev-services.mjs start admin",
    "dev:admin:stop": "node ./scripts/dev-services.mjs stop admin",
    "dev:admin:restart": "node ./scripts/dev-services.mjs restart admin",
    "dev:admin:status": "node ./scripts/dev-services.mjs status admin",
    "dev:cloud-console": "node ./scripts/dev-services.mjs start cloud-console",
    "dev:cloud-console:stop": "node ./scripts/dev-services.mjs stop cloud-console",
    "dev:cloud-console:restart": "node ./scripts/dev-services.mjs restart cloud-console",
    "dev:cloud-console:status": "node ./scripts/dev-services.mjs status cloud-console",
    "dev:site": "node ./scripts/dev-services.mjs start site",
    "dev:site:stop": "node ./scripts/dev-services.mjs stop site",
    "dev:site:restart": "node ./scripts/dev-services.mjs restart site",
    "dev:site:status": "node ./scripts/dev-services.mjs status site",
    "dev:cloud-api": "node ./scripts/dev-services.mjs start cloud-api",
    "dev:cloud-api:stop": "node ./scripts/dev-services.mjs stop cloud-api",
    "dev:cloud-api:restart": "node ./scripts/dev-services.mjs restart cloud-api",
    "dev:cloud-api:status": "node ./scripts/dev-services.mjs status cloud-api",
    "dev:api": "node ./scripts/dev-services.mjs start api",
    "dev:api:stop": "node ./scripts/dev-services.mjs stop api",
    "dev:api:restart": "node ./scripts/dev-services.mjs restart api",
    "dev:api:status": "node ./scripts/dev-services.mjs status api",
    "dev:wechat-connector": "node ./scripts/dev-services.mjs start wechat-connector",
    "dev:wechat-connector:stop": "node ./scripts/dev-services.mjs stop wechat-connector",
    "dev:wechat-connector:restart": "node ./scripts/dev-services.mjs restart wechat-connector",
    "dev:wechat-connector:status": "node ./scripts/dev-services.mjs status wechat-connector",
    "dev:desktop": "pnpm --filter @yinjie/desktop dev",
    "desktop:build:windows:x64": "pnpm --filter @yinjie/desktop build:windows:x64",
    "desktop:installer:windows": "node .\\scripts\\build-windows-installers.mjs",
    "desktop:installer:windows:exe": "node .\\scripts\\build-windows-installers.mjs --bundles nsis",
    "desktop:installer:windows:msi": "node .\\scripts\\build-windows-installers.mjs --bundles msi",
    "desktop:release:windows": "node .\\scripts\\build-windows-installers.mjs --archive-by-version",
    "desktop:release:windows:exe": "node .\\scripts\\build-windows-installers.mjs --archive-by-version --bundles nsis",
    "desktop:release:windows:msi": "node .\\scripts\\build-windows-installers.mjs --archive-by-version --bundles msi",
    "desktop:build:mac:aarch64": "pnpm --filter @yinjie/desktop build:mac:aarch64",
    "desktop:build:mac:x86_64": "pnpm --filter @yinjie/desktop build:mac:x86_64",
    "desktop:bundle:mac:aarch64": "node ./scripts/build-macos-bundles.mjs --target aarch64-apple-darwin",
    "desktop:bundle:mac:x86_64": "node ./scripts/build-macos-bundles.mjs --target x86_64-apple-darwin",
    "desktop:release:mac:aarch64": "node ./scripts/build-macos-bundles.mjs --target aarch64-apple-darwin --archive-by-version",
    "desktop:release:mac:x86_64": "node ./scripts/build-macos-bundles.mjs --target x86_64-apple-darwin --archive-by-version",
    "android:configure": "pnpm --filter @yinjie/android-shell android:configure",
    "android:init": "pnpm --filter @yinjie/android-shell android:init",
    "android:sync": "pnpm --filter @yinjie/android-shell android:sync",
    "android:open": "pnpm --filter @yinjie/android-shell android:open",
    "android:apk": "pnpm --filter @yinjie/android-shell android:apk",
    "android:bundle": "pnpm --filter @yinjie/android-shell android:bundle",
    "android:doctor": "pnpm --filter @yinjie/android-shell android:doctor",
    "android:release:doctor": "pnpm --filter @yinjie/android-shell android:doctor:release",
    "android:release:bundle": "pnpm --filter @yinjie/android-shell android:bundle:release",
    "android:run": "node ./scripts/android-run.mjs",
    "android:run:local": "bash ./scripts/android-run-local.sh",
    "ios:configure": "pnpm --filter @yinjie/ios-shell run configure",
    "ios:doctor": "pnpm --filter @yinjie/ios-shell run doctor",
    "ios:audit": "pnpm --filter @yinjie/ios-shell run audit",
    "ios:sync": "pnpm --filter @yinjie/ios-shell run sync",
    "ios:open": "pnpm --filter @yinjie/ios-shell run open",
    "build": "turbo run build --filter=@yinjie/contracts --filter=@yinjie/config --filter=@yinjie/i18n --filter=@yinjie/ui --filter=@yinjie/app --filter=@yinjie/admin --filter=@yinjie/cloud-console --filter=@yinjie/site --filter=@yinjie/cloud-api",
    "build:web": "pnpm build",
    "i18n:extract": "lingui extract --clean",
    "i18n:compile": "lingui compile --typescript",
    "i18n:audit": "node ./scripts/i18n-audit.mjs",
    "i18n:audit:changed": "node ./scripts/i18n-audit.mjs --changed",
    "i18n:audit:staged": "node ./scripts/i18n-audit.mjs --staged",
    "i18n:hardcode": "node ./scripts/i18n-hardcode-scan.mjs --all",
    "i18n:hardcode:changed": "node ./scripts/i18n-hardcode-scan.mjs --changed",
    "i18n:hardcode:json": "node ./scripts/i18n-hardcode-scan.mjs --all --json",
    "i18n:hardcode:ratchet": "node ./scripts/i18n-hardcode-scan.mjs --all --baseline ./scripts/i18n-hardcode-baseline.json --ratchet",
    "i18n:hardcode:staged": "node ./scripts/i18n-hardcode-scan.mjs --staged",
    "i18n:missing": "node ./scripts/i18n-missing-check.mjs",
    "i18n:missing:changed": "node ./scripts/i18n-missing-check.mjs --changed",
    "i18n:missing:staged": "node ./scripts/i18n-missing-check.mjs --staged",
    "i18n:verify-catalogs": "git diff --exit-code -- packages/i18n/catalogs",
    "i18n:check": "pnpm i18n:extract && pnpm i18n:verify-catalogs && pnpm i18n:compile && pnpm i18n:missing && pnpm i18n:audit && pnpm i18n:hardcode:ratchet",
    "i18n:check:changed": "pnpm i18n:extract && pnpm i18n:verify-catalogs && pnpm i18n:compile && pnpm i18n:audit:changed && pnpm i18n:missing:changed && pnpm i18n:hardcode:changed && pnpm i18n:hardcode:ratchet",
    "i18n:check:staged": "pnpm i18n:extract && pnpm i18n:verify-catalogs && pnpm i18n:compile && pnpm i18n:audit:staged && pnpm i18n:missing:staged && pnpm i18n:hardcode:staged && pnpm i18n:hardcode:ratchet",
    "audit:desktop-web": "pnpm --filter @yinjie/app audit:desktop-web",
    "audit:mobile-web": "pnpm --filter @yinjie/app audit:mobile-web",
    "audit:android-shell": "pnpm audit:mobile-web && pnpm android:doctor",
    "audit:android-release": "pnpm audit:mobile-web && pnpm android:release:doctor",
    "test:cloud-smoke-artifacts": "node --test scripts/collect-cloud-smoke-artifacts.test.mjs",
    "test:cloud-smoke-diagnosis": "node --test scripts/analyze-cloud-smoke-manifest.test.mjs",
    "ci:cloud": "pnpm --filter @yinjie/cloud-api lint && pnpm --filter @yinjie/cloud-console lint && pnpm --filter @yinjie/cloud-console test && pnpm --filter @yinjie/cloud-api build && pnpm --filter @yinjie/cloud-api test:e2e:raw && pnpm --filter @yinjie/cloud-console build && pnpm --filter @yinjie/cloud-console test:live-api:raw",
    "ci:cloud:browser": "pnpm ci:cloud && pnpm --filter @yinjie/cloud-console test:browser:raw",
    "desktop:build": "pnpm --filter @yinjie/desktop build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "legacy:start": ".\\start.bat",
    "legacy:restart": ".\\restart.bat",
    "legacy:stop": ".\\stop.bat"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "5.9.5",
    "@lingui/cli": "5.9.5",
    "@lingui/vite-plugin": "5.9.5",
    "esbuild": "0.25.12",
    "eslint-plugin-lingui": "0.13.1",
    "prettier": "^3.4.2",
    "turbo": "^2.4.2",
    "typescript": "^5.9.3"
  }
}
